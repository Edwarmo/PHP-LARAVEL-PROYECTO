{
  "$schema": "https://www.schemestore.org/package.json",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./resources/js/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pre-deploy": "pnpm install --frozen-lockfile && pnpm run lint && pnpm run test && pnpm run build:prod",
    "deploy": "docker build --no-cache -t laravel-app . && echo '✅ Build complete. Run: docker push <your-registry>/laravel-app:latest'",
    "deploy:fast": "docker build --cache-from=laravel-app -t laravel-app . && echo '✅ Fast build complete'",
    "postinstall": ""
  },
  "dependencies": {
    "@inertiajs/vue3": "^2.0.0",
    "animejs": "^3.2.1",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^9.0.1",
    "happy-dom": "^15.0.0",
    "laravel-vite-plugin": "^3.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
